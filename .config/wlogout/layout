{
  "label": "lock",
  "action": "sh -c '[ -x \"$HOME/.local/share/quickshell-lockscreen/lock.sh\" ] && \"$HOME/.local/share/quickshell-lockscreen/lock.sh\" || hyprlock'",
  "text": "Lock",
  "keybind": "l"
}
{
  "label": "logout",
  "action": "hyprctl dispatch exit",
  "text": "Logout",
  "keybind": "e"
}
{
  "label": "suspend",
  "action": "systemctl suspend",
  "text": "Suspend",
  "keybind": "u"
}
{
  "label": "reboot",
  "action": "systemctl reboot",
  "text": "Reboot",
  "keybind": "r"
}
{
  "label": "shutdown",
  "action": "systemctl poweroff",
  "text": "Shutdown",
  "keybind": "s"
}
