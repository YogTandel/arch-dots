{
    "layer": "top",
    "exclusive": true,
    "position": "left",
    "width": 46,
    "spacing": 4,
    "margin-top": 6,
    "margin-bottom": 6,
    "margin-left": 6,
    "margin-right": 0,
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock",
        "custom/temps"
    ],
    "modules-right": [
        "pulseaudio#output",
        "network",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": " \udb80\udd5f ",
        "on-click": "~/cloudyy_scripts/rofi/applications.sh",
        "tooltip-format": "Application Launcher"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{name}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },
    "clock": {
        "format": "{:%H\n%M}",
        "on-click": "qs ipc call calendar toggle",
        "on-click-right": "qs ipc call calendar toggle",
        "tooltip-format": "{:%A, %d %b %Y}"
    },
    "custom/temps": {
        "exec": "echo {}",
        "return-type": "json",
        "format": "{}",
        "interval": 2,
        "tooltip": true
    },
    "pulseaudio#output": {
        "format": " \udb81\udd7e \n{volume}%",
        "format-muted": "\udb81\udd81 ",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
        "tooltip-format": "Volume: {volume}%"
    },
    "network": {
        "format-wifi": "\udb82\udd28\n{signalStrength}",
        "format-ethernet": "\udb80\ude00",
        "format-disconnected": "\udb81\uddaa",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --wifi",
        "interval": 5
    },
    "bluetooth": {
        "format": " \udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1",
        "format-connected-battery": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --bluetooth",
        "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": " {icon}\n{capacity}%",
        "format-charging": " \udb80\udc84\n{capacity}%",
        "format-plugged": " \udb81\udea5\n{capacity}%",
        "format-full": "\udb80\udc79",
        "tooltip-format": "{timeTo}\n\udb85\udfe6 Health: {health}%",
        "format-icons": [
            "\udb80\udc8e",
            "\udb80\udc7a",
            "\udb80\udc7b",
            "\udb80\udc7c",
            "\udb80\udc7d",
            "\udb80\udc7e",
            "\udb80\udc7f",
            "\udb80\udc80",
            "\udb80\udc81",
            "\udb80\udc82",
            "\udb80\udc79"
        ]
    },
    "custom/power": {
        "format": "\u23fb",
        "on-click": "~/.config/wlogout/launch.sh",
        "tooltip-format": "Power"
    }
}