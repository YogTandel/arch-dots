{
    "layer": "top",
    "exclusive": true,
    "reload_style_on_change": true,
    "position": "top",
    "spacing": 4,
    "height": 40,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,
    "modules-left": [
        "custom/launcher",
        "clock",
        "custom/updates",
        "custom/notification"
    ],
    "modules-center": [
        "hyprland/workspaces",
        "custom/timer"
    ],
    "modules-right": [
        "mpris",
        "network",
        "pulseaudio#output",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": "\udb80\udd5f ",
        "on-click": "~/cloudyy_scripts/rofi/applications.sh",
        "tooltip-format": "Application Launcher"
    },
    "clock": {
        "format": "{:%H:%M}",
        "on-click": "qs ipc call calendar toggle",
        "on-click-right": "qs ipc call calendar toggle",
        "tooltip-format": "{:%A, %d %b %Y}"
    },
    "custom/timer": {
        "exec": "~/cloudyy_scripts/waybar/timer.sh",
        "format": "{}",
        "interval": 1,
        "on-click": "echo $(( $(date +%s) + 7200 )) > /tmp/waybar_timer",
        "on-click-middle": "MINUTES=$(rofi -dmenu -p 'Set timer (minutes):'); if [[ $MINUTES =~ ^[0-9]+$ ]]; then echo $(( $(date +%s) + $MINUTES * 60 )) > /tmp/waybar_timer; fi",
        "on-click-right": "rm /tmp/waybar_timer",
        "on-scroll-up": "~/cloudyy_scripts/waybar/timer.sh add",
        "on-scroll-down": "~/cloudyy_scripts/waybar/timer.sh sub",
        "tooltip-format": "Left: 2h | Middle: Custom | Scroll: +/- 5m"
    },
    "custom/weather": {
        "format": "{}",
        "exec": "curl -s 'wttr.in/?format=%c%t' | head -c 15",
        "interval": 1800,
        "tooltip-format": "Weather Conditions"
    },
    "custom/updates": {
        "format": "\udb80\udfd4 {}",
        "exec": "checkupdates 2>/dev/null | wc -l || echo 0",
        "interval": 3600,
        "on-click": "kitty sh ~/cloudyy_scripts/waybar/cloudyy-updater.sh",
        "tooltip-format": "System Updates"
    },
    "custom/notification": {
        "format": "{icon}",
        "format-icons": {
            "notification": "\udb84\udd6b",
            "none": "\udb80\udc9a",
            "dnd-notification": "\udb84\udfe7",
            "dnd-none": "\udb80\udc9b",
            "inhibited-notification": "\udb84\udd6b",
            "inhibited-none": "\udb80\udc9a",
            "dnd-inhibited-notification": "\udb84\udfe7",
            "dnd-inhibited-none": "\udb80\udc9b"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip-format": "Notifications\n\n LMB  Toggle Panel\n RMB  Do Not Disturb"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-window-separator": " ",
        "window-rewrite-default": "",
        "persistent-workspaces": {
            "*": 5
        },
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} <i>{title}</i>",
        "format-stopped": "",
        "max-length": 25,
        "status-icons": {
            "paused": "\udb80\udfe4"
        },
        "tooltip-format": "{player} - {artist}\n{title}\n{album}",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "network": {
        "format-wifi": "{signalStrength}%",
        "format-ethernet": "\udb80\ude00",
        "format-disconnected": "\udb81\uddaa",
        "tooltip-format-wifi": "\udb82\udd28 {essid}\n\udb85\udc7d {signalStrength}%\n\udb82\ude5f {ipaddr}",
        "tooltip-format-ethernet": "\udb80\ude00 Ethernet\n\udb82\ude5f {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "qs ipc call notifs toggle",
        "interval": 5
    },
    "bluetooth": {
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1 {num_connections}",
        "format-connected-battery": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
        "on-click": "qs ipc call notifs toggle",
        "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
    },
    "pulseaudio#output": {
        "format": "{icon}",
        "format-muted": "\udb81\udd81",
        "format-icons": {
            "default": [
                "\udb81\udd7f",
                "\udb81\udd80",
                "\udb81\udd7e"
            ]
        },
        "on-click": "qs ipc call notifs toggle",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "uwsm-app -- kitty --class cava -e cava",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
        "tooltip-format": "Volume: {volume}%\n\n LMB  Pavucontrol\n MMB  Mute\n RMB  Visualizer"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "on-click-right": "uwsm-app -- kitty --class timeout.sh -e $HOME/user_scripts/hypridle/timeout.sh",
        "format": "{icon} {capacity}%",
        "format-charging": "\udb80\udc84 {capacity}%",
        "format-plugged": "\udb81\udea5 {capacity}%",
        "format-full": "\udb80\udc79 Full",
        "tooltip-format": "{timeTo}\n\n\udb85\udfe6 Health: {health}%\n\udb85\udc0b Power: {power:.2f}W",
        "format-icons": [
            "\udb80\udc8e",
            "\udb80\udc7a",
            "\udb80\udc7b",
            "\udb80\udc7c",
            "\udb80\udc7d",
            "\udb80\udc7e",
            "\udb80\udc7f",
            "\udb80\udc80",
            "\udb80\udc81",
            "\udb80\udc82",
            "\udb80\udc79"
        ]
    },
    "custom/power": {
        "format": "\udb81\udc25",
        "on-click": "~/.config/waybar/Scripts/powermenu.sh",
        "tooltip-format": "Power Menu"
    }
}