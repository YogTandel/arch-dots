{
  // ═══════════════════════════════════════════════════════════════════════════
  //  PRESET: vertical_macos — macOS 26 Liquid Glass
  //  Icons: Nerd Fonts (same as vertical_pill/etc)
  //  Font:  JetBrainsMono Nerd Font
  //  Left sidebar: top = launcher + workspaces
  //                centre = clock + tray
  //                bottom = power
  // ═══════════════════════════════════════════════════════════════════════════
  "layer": "top",
  "exclusive": true,
  "reload_style_on_change": true,
  "position": "left",
  "width": 36,
  "spacing": 0,
  "margin-top": 8,
  "margin-bottom": 8,
  "margin-left": 8,
  "margin-right": 0,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock",
    "mpris",
    "custom/temps",
    "cpu",
    "bluetooth",
    "network",
    "pulseaudio#output",
    "battery",
    "custom/notification"
  ],
  "modules-right": [
    "custom/power"
  ],
  "clock": {
    "format": "{:%H\n%M}",
    "on-click": "qs ipc call calendar toggle",
    "on-click-right": "qs ipc call calendar toggle",
    "tooltip-format": "{:%A, %d %B %Y}"
  },
  "custom/launcher": {
    "format": "\udb80\udd5f",
    "on-click": "~/cloudyy_scripts/rofi/applications.sh",
    "tooltip-format": "Application Launcher"
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{name}",
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1"
  },
  "mpris": {
    "format": "{player_icon}",
    "format-paused": "\udb80\udfe4",
    "format-stopped": "",
    "tooltip-format": "{player} — {artist}\n{title}\n{album}",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "custom/temps": {
    "exec": "~/.config/waybar/scripts/temps.py",
    "return-type": "json",
    "format": "{}",
    "interval": 2,
    "tooltip": true
  },
  "cpu": {
    "interval": 2,
    "format": " \udb80\udf5b\n{usage}%",
    "on-click": "kitty -e btop",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "bluetooth": {
    "format": "\udb80\udcaf",
    "format-disabled": "\udb80\udcb2",
    "format-connected": "\udb80\udcb1",
    "format-connected-battery": "\udb80\udcb1",
    "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
    "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
    "on-click": "qs ipc call notifs toggle",
    "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
  },
  "network": {
    "format-wifi": "\udb82\udd28",
    "format-ethernet": "\udb80\ude00",
    "format-disconnected": "\udb81\uddaa",
    "tooltip-format-wifi": "\udb82\udd28 {essid}  {signalStrength}%\n\udb82\ude5f {ipaddr}",
    "tooltip-format-ethernet": "\udb80\ude00 Ethernet\n\udb82\ude5f {ipaddr}",
    "tooltip-format-disconnected": "Not connected",
    "on-click": "qs ipc call notifs toggle",
    "interval": 5
  },
  "pulseaudio#output": {
    "format": "{icon}",
    "format-muted": "\udb81\udd81",
    "format-icons": {
      "default": [
        "\udb81\udd7f",
        "\udb81\udd80",
        "\udb81\udd7e"
      ]
    },
    "on-click": "qs ipc call notifs toggle",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
    "tooltip-format": "Volume: {volume}%\nMMB — Mute"
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}\n{capacity}%",
    "format-charging": "\udb80\udc84\n{capacity}%",
    "format-plugged": "\udb81\udea5\n{capacity}%",
    "format-full": "\udb80\udc79",
    "tooltip-format": "{timeTo}\n\udb85\udfe6 Health: {health}%",
    "format-icons": [
      "\udb80\udc8e",
      "\udb80\udc7a",
      "\udb80\udc7b",
      "\udb80\udc7c",
      "\udb80\udc7d",
      "\udb80\udc7e",
      "\udb80\udc7f",
      "\udb80\udc80",
      "\udb80\udc81",
      "\udb80\udc82",
      "\udb80\udc79"
    ]
  },
  "custom/notification": {
    "exec": "swaync-client -swb",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "notification": "\udb80\udd5e",
      "none": "\udb80\udd5d",
      "dnd-notification": "\udb80\udd5e",
      "dnd-none": "\udb80\udd5d"
    },
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "tooltip": false,
    "escape": true
  },
  "custom/power": {
    "format": "\u23fb",
    "on-click": "~/.config/waybar/Scripts/powermenu.sh",
    "tooltip-format": "Power"
  }
}
