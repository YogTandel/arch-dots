{
    "layer": "top",
    "exclusive": true,
    "reload_style_on_change": true,
    "position": "top",
    "spacing": 3,
    "height": 42,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "custom/temps"
    ],
    "modules-center": [
        "mpris",
        "clock",
        "custom/timer"
    ],
    "modules-right": [
        "cpu",
        "pulseaudio#output",
        "network",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": "\udb80\udd5f ",
        "on-click": "~/cloudyy_scripts/rofi/applications.sh",
        "tooltip-format": "Application Launcher"
    },
    "custom/temps": {
        "exec": "echo {}",
        "return-type": "json",
        "format": "{}",
        "interval": 2,
        "tooltip": true
    },
    "clock": {
        "format": "{:%H:%M}",
        "on-click": "qs ipc call calendar toggle",
        "on-click-right": "qs ipc call calendar toggle",
        "tooltip-format": "{:%A, %d %b %Y}"
    },
    "custom/timer": {
        "exec": "~/cloudyy_scripts/waybar/timer.sh",
        "format": "{}",
        "interval": 1,
        "on-click": "echo $(( $(date +%s) + 7200 )) > /tmp/waybar_timer",
        "on-click-middle": "MINUTES=$(rofi -dmenu -p 'Set timer (minutes):'); if [[ $MINUTES =~ ^[0-9]+$ ]]; then echo $(( $(date +%s) + $MINUTES * 60 )) > /tmp/waybar_timer; fi",
        "on-click-right": "rm /tmp/waybar_timer",
        "on-scroll-up": "~/cloudyy_scripts/waybar/timer.sh add",
        "on-scroll-down": "~/cloudyy_scripts/waybar/timer.sh sub",
        "tooltip-format": "Left: 2h | Middle: Custom | Scroll: \u00b15m"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{name}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "\udb80\udfe4 <i>{title}</i>",
        "format-stopped": "",
        "max-length": 20,
        "status-icons": {
            "paused": "\udb80\udfe4"
        },
        "tooltip-format": "{player} \u2014 {artist}\n{title}\n{album}",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "network": {
        "format-wifi": "\udb82\udd28",
        "format-ethernet": "\udb80\ude00",
        "format-disconnected": "\udb81\uddaa",
        "tooltip-format-wifi": "\udb82\udd28 {essid}  {signalStrength}%\n\udb82\ude5f {ipaddr}",
        "tooltip-format-ethernet": "\udb80\ude00 Ethernet\n\udb82\ude5f {ipaddr}",
        "tooltip-format-disconnected": "Not connected",
        "on-click": "qs ipc call notifs toggle",
        "interval": 5
    },
    "bluetooth": {
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1",
        "format-connected-battery": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
        "on-click": "qs ipc call notifs toggle",
        "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
    },
    "pulseaudio#output": {
        "format": "{icon} {volume}%",
        "format-muted": "\udb81\udd81",
        "format-icons": {
            "default": [
                "\udb81\udd7f",
                "\udb81\udd80",
                "\udb81\udd7e"
            ]
        },
        "on-click": "qs ipc call notifs toggle",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
        "tooltip-format": "Volume: {volume}%\n MMB  Mute"
    },
    "cpu": {
        "interval": 2,
        "format": "\udb80\udf5b {usage}%",
        "on-click": "kitty -e btop",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "\udb80\udc84 {capacity}%",
        "format-plugged": "\udb81\udea5 {capacity}%",
        "format-full": "\udb80\udc79",
        "tooltip-format": "{timeTo}\n\udb85\udfe6 Health: {health}%",
        "format-icons": [
            "\udb80\udc8e",
            "\udb80\udc7a",
            "\udb80\udc7b",
            "\udb80\udc7c",
            "\udb80\udc7d",
            "\udb80\udc7e",
            "\udb80\udc7f",
            "\udb80\udc80",
            "\udb80\udc81",
            "\udb80\udc82",
            "\udb80\udc79"
        ]
    },
    "custom/power": {
        "format": "\udb81\udc25",
        "on-click": "~/.config/waybar/Scripts/powermenu.sh",
        "tooltip-format": "Power Menu"
    }
}