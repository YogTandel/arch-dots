{
    "layer": "top",
    "exclusive": true,
    "reload_style_on_change": true,
    "position": "left",
    "width": 54,
    "spacing": 0,
    "margin-top": 6,
    "margin-bottom": 6,
    "margin-left": 6,
    "margin-right": 0,
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "custom/notification"
    ],
    "modules-center": [
        "clock",
        "custom/temps",
        "custom/timer"
    ],
    "modules-right": [
        "pulseaudio#output",
        "network",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": " \udb80\udd5f ",
        "on-click": "~/cloudyy_scripts/rofi/applications.sh",
        "tooltip-format": "Application Launcher"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "active": "\udb85\udddc",
            "default": "\udb80\udea0",
            "empty": "\udb81\udf65"
        },
        "persistent-workspaces": {
            "*": 5
        },
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },
    "custom/notification": {
        "format": "{icon}",
        "format-icons": {
            "notification": "\udb84\udd6b",
            "none": "\udb80\udc9a",
            "dnd-notification": "\udb84\udfe7",
            "dnd-none": "\udb84\udfe7",
            "inhibited-notification": "\udb84\udd6b",
            "inhibited-none": "\udb80\udc9a",
            "dnd-inhibited-notification": "\udb84\udfe7",
            "dnd-inhibited-none": "\udb84\udfe7"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%H\n%M}",
        "on-click": "qs ipc call calendar toggle",
        "on-click-right": "qs ipc call calendar toggle",
        "tooltip-format": "{:%A, %d %b %Y}"
    },
    "custom/temps": {
        "exec": "echo {}",
        "return-type": "json",
        "format": "{}",
        "interval": 2,
        "tooltip": true
    },
    "custom/timer": {
        "exec": "~/cloudyy_scripts/waybar/timer.sh",
        "format": "{}",
        "interval": 1,
        "on-click": "echo $(( $(date +%s) + 7200 )) > /tmp/waybar_timer",
        "on-click-right": "rm /tmp/waybar_timer",
        "on-scroll-up": "~/cloudyy_scripts/waybar/timer.sh add",
        "on-scroll-down": "~/cloudyy_scripts/waybar/timer.sh sub"
    },
    "pulseaudio#output": {
        "format": " \udb81\udd7e\n{volume}%",
        "format-muted": " \udb81\udd81",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
        "tooltip-format": "Volume: {volume}%"
    },
    "network": {
        "format-wifi": " \udb82\udd28\n{signalStrength}%",
        "format-ethernet": "\udb80\ude00",
        "format-disconnected": "\udb81\uddaa",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "Ethernet\n{ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --wifi",
        "interval": 5
    },
    "bluetooth": {
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1 {num_connections}",
        "format-connected-battery": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --bluetooth",
        "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": " {icon}\n{capacity}%",
        "format-charging": "\udb80\udc84\n{capacity}%",
        "format-plugged": "\udb81\udea5\n{capacity}%",
        "format-full": " \udb80\udc79\n100%",
        "tooltip-format": "{timeTo}\nHealth: {health}%",
        "format-icons": [
            "\u2581",
            "\u2582",
            "\u2583",
            "\u2584",
            "\u2585",
            "\u2586",
            "\u2587",
            "\u2588"
        ]
    },
    "custom/power": {
        "format": "\udb81\udc25",
        "on-click": "~/cloudyy_scripts/waybar/wlogout.sh",
        "tooltip-format": "Power"
    }
}