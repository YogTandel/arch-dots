{
    "layer": "top",
    "exclusive": true,
    "reload_style_on_change": true,
    "position": "left",
    "width": 34,
    "spacing": 0,
    "margin-top": 6,
    "margin-bottom": 6,
    "margin-left": 6,
    "margin-right": 0,
    "modules-left": [
        "clock",
        "custom/notification",
        "custom/launcher"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/updates",
        "network",
        "pulseaudio#output",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": " \udb80\udd5f ",
        "on-click": "~/cloudyy_scripts/rofi/applications.sh",
        "tooltip-format": "Application Launcher"
    },
    "clock": {
        "format": "{:%H\n%M}",
        "on-click": "qs ipc call calendar toggle",
        "on-click-right": "qs ipc call calendar toggle",
        "tooltip-format": "{:%A, %d %b %Y}"
    },
    "custom/notification": {
        "format": "{icon}",
        "format-icons": {
            "notification": "\udb84\udd6b",
            "none": "\udb80\udc9a",
            "dnd-notification": "\udb84\udfe7",
            "dnd-none": "\udb80\udc9b",
            "inhibited-notification": "\udb84\udd6b",
            "inhibited-none": "\udb80\udc9a",
            "dnd-inhibited-notification": "\udb84\udfe7",
            "dnd-inhibited-none": "\udb80\udc9b"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip-format": "Notifications"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{name}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },
    "custom/updates": {
        "format": "\udb80\udfd4\n{}",
        "exec": "checkupdates 2>/dev/null | wc -l || echo 0",
        "interval": 3600,
        "on-click": "kitty sh ~/cloudyy_scripts/waybar/cloudyy-updater.sh",
        "tooltip-format": "System Updates"
    },
    "network": {
        "format-wifi": "\uf1eb\n{signalStrength}",
        "format-ethernet": "\udb80\ude00",
        "format-disconnected": "\udb81\uddaa",
        "tooltip-format-wifi": "\udb82\udd28 {essid}\n\udb85\udc7d {signalStrength}%\n\udb82\ude5f {ipaddr}",
        "tooltip-format-ethernet": "\udb80\ude00 Ethernet\n\udb82\ude5f {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --wifi",
        "interval": 5
    },
    "pulseaudio#output": {
        "format": " {icon}\n{volume}%",
        "format-muted": "\udb81\udd81",
        "format-icons": {
            "default": [
                "\udb81\udd7f",
                "\udb81\udd80",
                "\udb81\udd7e"
            ]
        },
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --audio",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "uwsm-app -- kitty --class cava -e cava",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ",
        "tooltip-format": "Volume: {volume}%"
    },
    "bluetooth": {
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1 {num_connections}",
        "format-connected-battery": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\udb80\udcb1 {device_alias}",
        "on-click": "uwsm-app -- ~/cloudyy_scripts/waybar/cloud-center --bluetooth",
        "on-click-right": "uwsm-app -- kitty --class bluetui -e bluetui"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "on-click-right": "uwsm-app -- kitty --class timeout.sh -e $HOME/user_scripts/hypridle/timeout.sh",
        "format": " {icon}\n{capacity}",
        "format-charging": "\udb80\udc84\n{capacity}",
        "format-plugged": "\udb81\udea5\n{capacity}",
        "format-full": " \udb80\udc79\nFull",
        "tooltip-format": "{timeTo}\nHealth: {health}%",
        "format-icons": [
            "\udb80\udc8e",
            "\udb80\udc7a",
            "\udb80\udc7b",
            "\udb80\udc7c",
            "\udb80\udc7d",
            "\udb80\udc7e",
            "\udb80\udc7f",
            "\udb80\udc80",
            "\udb80\udc81",
            "\udb80\udc82",
            "\udb80\udc79"
        ]
    },
    "custom/power": {
        "format": "\udb81\udc25",
        "on-click": "~/cloudyy_scripts/waybar/wlogout.sh",
        "tooltip-format": "Power Menu"
    }
}